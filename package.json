{
  "name": "portsentry",
  "version": "1.0.0",
  "description": "PortSentry Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "pidusage": "^3.0.2"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.portsentry.app",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "PortSentry"
    },
    "files": [
      "main.js",
      "server.js",
      "portsentry.html",
      "splash.html",
      "icon.png"
    ]
  }
}
