{
  "name": "portsentry",
  "version": "1.0.0",
  "description": "PortSentry Desktop Application",
  "main": "main.js",
  "author": "JOJIN JOHN <https://www.linkedin.com/in/jojin-john/>",
  "homepage": "https://jojin1709.github.io/PortSentry/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jojin1709/PortSentry.git"
  },
  "bugs": {
    "url": "https://github.com/jojin1709/PortSentry/issues"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "pidusage": "^3.0.2"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.portsentry.app",
    "productName": "PortSentry",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico",
      "publisherName": "JOJIN JOHN",
      "legalTrademarks": "© 2026 JOJIN JOHN. All rights reserved."
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "PortSentry",
      "uninstallDisplayName": "PortSentry - Port Monitor by JOJIN JOHN",
      "license": "LICENSE",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    },
    "files": [
      "main.js",
      "server.js",
      "portsentry.html",
      "splash.html",
      "icon.png",
      "icon.ico"
    ]
  }
}
